# SpeedyTap Environment Variables

# Geliştirme ortamı
NODE_ENV=development

# Mobil Platform
VITE_PLATFORM=android
VITE_IS_MOBILE=true

# AdMob Konfigürasyonu
VITE_ADMOB_APP_ID=ca-app-pub-2923372871861852~6427894520
VITE_ADMOB_BANNER_ID=ca-app-pub-3940256099942544/6300978111
VITE_ADMOB_INTERSTITIAL_ID=ca-app-pub-3940256099942544/1033173712

# Mobil Performans Optimizasyonları
VITE_ENABLE_HARDWARE_ACCELERATION=true
VITE_ENABLE_HAPTIC_FEEDBACK=true
VITE_BATTERY_OPTIMIZATION=true

# API Endpoints (eğer backend olsaydı)
# VITE_API_BASE_URL=https://api.speedytap.com

# Analytics (eğer kullanılsaydı)
# VITE_ANALYTICS_ID=GA_MEASUREMENT_ID

# Debug Modları
VITE_DEBUG_MODE=false
VITE_SHOW_PERFORMANCE_MONITOR=false

# Oyun Ayarları
VITE_MAX_FPS=60
VITE_ENABLE_PARTICLE_EFFECTS=true
VITE_AUTO_SAVE_INTERVAL=5000 